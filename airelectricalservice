<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AIR Electrical Service | क्रांतिकारी वायरिंग और सुरक्षा</title>
    <style>
        :root {
            --air-blue: #00d4ff; /* आकाश जैसा नीला */
            --dark-bg: #0a0a0a;
            --card-bg: #1a1a1a;
            --accent: #ffcc00;
        }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: var(--dark-bg); color: white; margin: 0; }
        
        nav { display: flex; justify-content: space-between; align-items: center; padding: 15px 5%; background: #000; border-bottom: 2px solid var(--air-blue); position: sticky; top: 0; z-index: 1000; }
        .logo { font-size: 1.8rem; font-weight: bold; color: var(--air-blue); letter-spacing: 2px; }

        section { padding: 50px 8%; text-align: center; }
        .btn { background: var(--air-blue); color: #000; padding: 12px 25px; border: none; border-radius: 30px; cursor: pointer; font-weight: bold; text-decoration: none; transition: 0.3s; }
        .btn:hover { background: var(--accent); transform: scale(1.05); }

        /* गैलरी सेक्शन */
        .gallery-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 15px; margin-top: 30px; }
        .gallery-item { background: var(--card-bg); height: 200px; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 1px solid #333; overflow: hidden; }
        .gallery-item img { width: 100%; height: 100%; object-fit: cover; opacity: 0.7; }

        /* शॉपिंग कार्ड */
        .shop-container { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
        .product-card { background: var(--card-bg); padding: 20px; border-radius: 15px; border-bottom: 4px solid var(--air-blue); }

        .tracker-box { background: #111; padding: 30px; border-radius: 20px; border: 1px dashed var(--air-blue); max-width: 500px; margin: 0 auto; }
        input { padding: 12px; width: 80%; border-radius: 5px; border: 1px solid var(--air-blue); background: #000; color: white; margin-bottom: 15px; }
    </style>
</head>
<body>

<nav>
    <div class="logo">AIR ELECTRICAL</div>
    <div class="nav-links">
        <a href="#shop" style="color:white; text-decoration:none; margin-left:15px;">शॉपिंग</a>
        <a href="#gallery" style="color:white; text-decoration:none; margin-left:15px;">गैलरी</a>
        <a href="#contact" style="color:white; text-decoration:none; margin-left:15px;">संपर्क</a>
    </div>
</nav>

<section id="home">
    <h1 style="font-size: 3rem;">AIR Electrical Service</h1>
    <p style="font-size: 1.2rem; color: #ccc;">"तेज सेवा, सुरक्षित कल" - हम लाते हैं वायरिंग में क्रांति।</p>
    <p>★ 1 साल की फ्री वारंटी | प्रीमियम मैटेरियल ★</p>
    <br>
    <a href="#track" class="btn">अपना काम ट्रैक करें</a>
</section>

<section id="gallery" style="background: #111;">
    <h2>हमारा काम (Work Portfolio)</h2>
    <div class="gallery-grid">
        <div class="gallery-item"><p>पाइपिंग वर्क फोटो</p></div>
        <div class="gallery-item"><p>कंसील्ड वायरिंग फोटो</p></div>
        <div class="gallery-item"><p>बोर्ड फिनिशिंग फोटो</p></div>
    </div>
</section>

<section id="shop">
    <h2>क्रांतिकारी शॉपिंग स्टोर</h2>
    <div class="shop-container">
        <div class="product-card">
            <h3>Premium Cables</h3>
            <p>Fire Resistant</p>
            <button class="btn">🛒 खरीदें</button>
        </div>
        <div class="product-card">
            <h3>Smart Switches</h3>
            <p>Modern Finish</p>
            <button class="btn">🛒 खरीदें</button>
        </div>
    </div>
</section>

<section id="track">
    <div class="tracker-box">
        <h3>प्रोजेक्ट स्टेटस चेक करें</h3>
        <input type="text" id="projectID" placeholder="ID डालें (उदा: AIR-001)">
        <button class="btn" onclick="trackProject()">Search</button>
        <div id="statusResult" style="margin-top:20px; text-align: left;"></div>
    </div>
</section>

<section id="contact">
    <h2>संपर्क करें</h2>
    <p>📞 +91 XXXXX XXXXX</p>
    <a href="https://wa.me/91XXXXXXXXXX" class="btn" style="background: #25D366; color: white;">WhatsApp Chat</a>
</section>

<script>
    function trackProject() {
        const id = document.getElementById('projectID').value.toUpperCase();
        const res = document.getElementById('statusResult');

        const data = {
            "AIR-001": {
                progress: "90%",
                update: "मेन बोर्ड फिटिंग पूरी हो चुकी है।",
                paid: "₹12,000",
                due: "₹3,000"
            }
        };

        if(data[id]) {
            res.innerHTML = `
                <div style="background:#222; padding:15px; border-radius:10px;">
                    <p>📊 <b>प्रगति:</b> ${data[id].progress}</p>
                    <p>📝 <b>अपडेट:</b> ${data[id].update}</p>
                    <hr color="#333">
                    <p>✅ <b>जमा:</b> ${data[id].paid}</p>
                    <p>❌ <b>बकाया:</b> ${data[id].due}</p>
                </div>
            `;
        } else {
            res.innerHTML = "आईडी नहीं मिली।";
        }
    }
</script>

</body>
</html>
